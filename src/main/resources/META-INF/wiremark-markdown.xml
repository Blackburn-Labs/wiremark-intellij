<!-- Loaded only when the bundled Markdown plugin (org.intellij.plugins.markdown) is enabled. -->
<idea-plugin>
    <extensions defaultExtensionNs="org.intellij.markdown">
        <!-- dev3 (Part A): inject the wiremark bundle + glue into the Markdown preview so
             ```wireframe / ```wiremark fences render as SVGs. -->
        <browserPreviewExtensionProvider
            implementation="dev.wiremark.intellij.markdown.WiremarkPreviewExtension$Provider"/>

        <!-- Milestone 6 (dev5): map ```wireframe / ```wiremark fence info strings to the
             Wiremark language so the fence body gets in-editor syntax highlighting. -->
        <fenceLanguageProvider
            implementation="dev.wiremark.intellij.markdown.WiremarkFenceLanguageProvider"/>
    </extensions>
</idea-plugin>
